<Page x:Class="VUS_Assist_v._1._0.AddingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Добавление записей">
    <Grid Margin="30">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="➕ Добавление записей в базу данных" 
                       FontSize="24" FontWeight="Bold" Margin="0,0,0,30"/>

                <!-- Блок для ВЭК -->
                <GroupBox Header="Добавление ВЭК" Padding="15" Margin="0,0,0,20" FontSize="14">
                    <StackPanel>
                        <TextBlock Text="Количество записей для добавления:" Margin="0,0,0,10"/>
                        <TextBox x:Name="TxtVecCount" Width="200" Height="30" 
                             HorizontalAlignment="Left" FontSize="14"
                             Text="10" HorizontalContentAlignment="Center"/>

                        <Button Content="Добавить ВЭК" Width="200" Height="40" 
                            Margin="0,15,0,0" HorizontalAlignment="Left"
                            Click="AddVec_Click" FontSize="14" FontWeight="Bold"
                            Background="#27AE60" Foreground="White"/>

                        <TextBlock x:Name="TxtVecStatus" Margin="0,10,0,0" 
                               Foreground="Green" FontWeight="Bold" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <!-- Блок для подготовленных -->
                <GroupBox Header="Добавление Подготовленных" Padding="15" Margin="0,0,0,20" FontSize="14">
                    <StackPanel>
                        <TextBlock Text="Количество записей для добавления:" Margin="0,0,0,10"/>
                        <TextBox x:Name="TxtPreparedCount" Width="200" Height="30" 
                             HorizontalAlignment="Left" FontSize="14"
                             Text="5" HorizontalContentAlignment="Center"/>

                        <Button Content="Добавить подготовленных" Width="200" Height="40" 
                            Margin="0,15,0,0" HorizontalAlignment="Left"
                            Click="AddPrepared_Click" FontSize="14" FontWeight="Bold"
                            Background="#E67E22" Foreground="White"/>

                        <TextBlock x:Name="TxtPreparedStatus" Margin="0,10,0,0" 
                               Foreground="Green" FontWeight="Bold" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>


                <!-- Блок для импорта отправленных -->
                <GroupBox Header="Импорт отправленных из Excel" Padding="15" Margin="0,0,0,20" FontSize="14">
                    <StackPanel>
                        <TextBlock Text="Импортирует людей из Excel: не трогает уже отправленных, отсутствующих добавляет в БД, дату вызова и комиссию ставит случайно за 14–21 день до отправки." TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <Button Content="Импортировать отправленных" Width="240" Height="40"
                            HorizontalAlignment="Left" Click="ImportSent_Click" FontSize="14" FontWeight="Bold"
                            Background="#8E44AD" Foreground="White"/>
                        <TextBlock x:Name="TxtSentImportStatus" Margin="0,10,0,0"
                               Foreground="Green" FontWeight="Bold" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <!-- Общая информация -->
                <Border Background="#ECF0F1" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Информация:" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="• ВЭК: номер формата АВ1234 или 16001234567, дата за последние 14 дней" TextWrapping="Wrap"/>
                        <TextBlock Text="• Подготовленные: 10-значный номер, дата минимум через 3 дня после ВЭК" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        <TextBlock Text="• Все значения проверяются на уникальность во всей таблице" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>